{
  "Roots": [
    "<PATH TO OBSIDIAN NOTES>"
  ],
  "IncludeExtensions": [".md", ".txt"],
  "ExcludeGlobs": [".git", ".obsidian", "node_modules"],
  "Postgres": {
    "ConnectionString": "<POSTGRES CONNECTION STRING>"
  },
  "Embeddings": {
    "ApiKeyEnvVar": "<AZURE OPEN API KEY",
    "Model": "text-embedding-3-small",
    "BaseUrl": "https://<YOUR PATH HERE>.services.ai.azure.com/api/projects/rag-embeddings",
    "Dimensions": 1536,
    "TimeoutSeconds": 30,
    "MaxRetries": 2,
    "InitialBackoffMs": 250
  },
  "Chunking": {
    "MaxTokens": 500,
    "OverlapTokens": 80
  },
  "Watch": {
    "ReconcileIntervalMinutes": 30,
    "DebounceMilliseconds": 1000
  },
  "Search": {
    "VectorWeight": 0.65,
    "FtsWeight": 0.35,
    "CandidatePoolSize": 100
  },
  "Mcp": {
    "Port": 8787,
    "BindHost": "127.0.0.1",
    "DefaultTopK": 8
  },
  "Logging": {
    "Retention": {
      "Mode": "keep_all",
      "Days": null
    },
    "Mcp": {
      "MaxParamBytes": 16384,
      "MaxResultBytes": 32768
    }
  }
}
